<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.projet2.sceneControllers.EditTransactionController"
      spacing="15"
      alignment="CENTER"
      prefWidth="600"
      prefHeight="400">

    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

    <Label text="Edit Transaction"
           style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

    <TextField fx:id="amountField"      promptText="Amount"/>
    <TextField fx:id="categoryField"    promptText="Category"/>
    <TextField fx:id="descriptionField" promptText="Description"/>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Save"   onAction="#handleSave"/>
        <Button text="Cancel" onAction="#handleCancel"/>
    </HBox>

</VBox>