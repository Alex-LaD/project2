<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.projet2.sceneControllers.TransactionDetailController"
      spacing="15"
      prefWidth="700"
      prefHeight="500">

    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="My Transactions"
           style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

    <TableView fx:id="detailTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colAmount"      text="Amount"      prefWidth="100"/>
            <TableColumn fx:id="colCategory"    text="Category"    prefWidth="120"/>
            <TableColumn fx:id="colDescription" text="Description" prefWidth="200"/>
            <TableColumn fx:id="colDate"        text="Date"        prefWidth="120"/>
        </columns>
    </TableView>

    <HBox spacing="10">
        <Button text="Edit Selected"   onAction="#handleEdit"/>
        <Button text="Delete Selected" onAction="#handleDelete"/>
        <Button text="Back"            onAction="#handleBack"/>
    </HBox>

</VBox>