<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.projet2.sceneControllers.DashboardController"
      spacing="15"
      prefWidth="700"
      prefHeight="500">

    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Personal Budget Dashboard"
           style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

    <HBox spacing="20">
        <Label fx:id="usernameLabel" text="User: "/>
        <Label fx:id="balanceLabel" text="Balance: $0.00"
               style="-fx-font-weight: bold;"/>
    </HBox>

    <TableView fx:id="transactionTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colAmount"      text="Amount"      prefWidth="100"/>
            <TableColumn fx:id="colCategory"    text="Category"    prefWidth="120"/>
            <TableColumn fx:id="colDescription" text="Description" prefWidth="200"/>
            <TableColumn fx:id="colDate"        text="Date"        prefWidth="120"/>
        </columns>
    </TableView>

    <HBox spacing="10">
        <Button text="Add Transaction" onAction="#goToTransactionScene"/>
        <Button text="Delete Selected" onAction="#handleDeleteTransaction"/>
    </HBox>

</VBox>