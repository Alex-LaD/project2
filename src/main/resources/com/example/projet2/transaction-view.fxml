<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.projet2.sceneControllers.TransactionController"
      spacing="15"
      alignment="CENTER"
      prefWidth="600"
      prefHeight="400">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <Label text="Add Transaction"
           style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <TextField fx:id="amountField" promptText="Amount"/>
    <TextField fx:id="categoryField" promptText="Category"/>
    <TextField fx:id="descriptionField" promptText="Description"/>

    <Button text="Add Transaction" onAction="#addTransaction"/>
    <Button text="Back to Dashboard" onAction="#goBackToDashboard"/>

</VBox>